{
    "manifest_version": 3,

    "name": "TaskFlow",

    "version": "1.0.0",

    "description": "AI workflow organizer",

    "permissions": [
        "tabs",
        "storage"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "128": "assets/logo.png"
        }
    },

    "icons": {
        "128": "assets/logo.png"
    }
}