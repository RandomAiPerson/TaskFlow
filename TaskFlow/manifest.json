{
    "manifest_version": 3,

    "name": "TaskFlow",

    "version": "1.0.0",

    "description": "AI workflow organizer",

    "permissions": [
        "tabs",
        "storage"
    ],

    "host_permissions": [
        "<all_urls>",
        "https://api.featherless.ai/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "action": {
        "default_popup": "popup/popup.html"
    }
}